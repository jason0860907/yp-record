# ASR (vLLM server)
ASR_BASE_URL=http://localhost:8006/v1
ASR_MODEL=Qwen/Qwen3-ASR-1.7B
ASR_TIMEOUT=20.0

# Audio
SAMPLE_RATE=16000
BUFFER_SECONDS=10.0

# Forced Aligner
ALIGNER_ENABLED=true
ALIGNER_MODEL=Qwen/Qwen3-ForcedAligner-0.6B
ALIGNER_DEVICE=auto
ALIGNER_LANGUAGE=zh
ALIGNER_AUTO_ON_SESSION_END=true

# Speaker Diarization
DIARIZATION_ENABLED=true
DIARIZATION_HF_TOKEN=hf_your_token_here
DIARIZATION_DEVICE=auto
# DIARIZATION_MIN_SPEAKERS=2
# DIARIZATION_MAX_SPEAKERS=4

# LLM Extraction (transcript polish + meeting note)
EXTRACT_ENABLED=false
EXTRACT_BASE_URL=http://localhost:8000/v1
EXTRACT_MODEL=cyankiwi/Qwen3.5-9B-AWQ-4bit
EXTRACT_TEMPERATURE=0.3
EXTRACT_TIMEOUT=120.0
EXTRACT_AUTO_ON_SESSION_END=true

# Notion Export
NOTION_API_KEY=secret_your_notion_key
NOTION_DATABASE_ID=your_database_id

# Server
HOST=0.0.0.0
PORT=8080

# Storage
STORAGE_DIR=storage/sessions
